# ============================================================
# Криптовалютный торговый терминал — шаблон переменных среды
# Скопируйте этот файл в .env и заполните значения
# ============================================================

# --- BingX API (только для Execution Engine) ---
BINGX_API_KEY=your_api_key_here
BINGX_API_SECRET=your_api_secret_here

# --- Внешние API ---
NEWS_API_KEY=your_newsapi_key_here

# --- Настройки системы ---
LOG_LEVEL=INFO
DB_PATH=data/terminal.db

# --- Торговые параметры ---
MAX_RISK_PER_TRADE=0.02
MAX_OPEN_POSITIONS=5
MAX_DAILY_DRAWDOWN=0.05
MAX_TOTAL_DRAWDOWN=0.15
DEFAULT_LEVERAGE=5

# --- Символы (опционально, по умолчанию 5 пар) ---
SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,BNB/USDT,XRP/USDT

# --- Начальный капитал (виртуальный для paper trading) ---
INITIAL_CAPITAL=10000

# --- Режим работы: live / paper ---
# live  = реальные ордера через API
# paper = dry_run (логирование без исполнения)
TRADING_MODE=paper

# --- Режим исполнения: auto / semi_auto / alert_only ---
EXECUTION_MODE=alert_only

# --- Windows: UTF-8 в консоли (добавьте в environment или запускайте через run.bat) ---
PYTHONUTF8=1
